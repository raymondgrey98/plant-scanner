# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/floraiq
DATABASE_SSL=false

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# ─── AI Providers (use at least ONE) ────────────────────────────────────────
# Priority: Gemini → OpenAI → Claude → OpenRouter (fallback, free)

# Google Gemini (FREE tier available — recommended first choice)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI GPT-4o (best quality)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Anthropic Claude (excellent reasoning)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenRouter (FREE fallback — works without key if using free models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_TEXT_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# ─── Payments ────────────────────────────────────────────────────────────────
# Stripe (Credit/Debit cards globally)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Global)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# PayMongo — GCash / Maya (Philippines)
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_PUBLIC_KEY=pk_test_...

# Premium price in USD (default: 9.99)
PREMIUM_PRICE_USD=9.99

# ─── Cloud Storage ────────────────────────────────────────────────────────────
# Cloudinary (optional — files stored locally if not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
EMAIL_FROM=FloraIQ <noreply@floraiq.app>

# ─── Weather ─────────────────────────────────────────────────────────────────
# OpenWeatherMap (optional — falls back to free open-meteo.com)
OPENWEATHER_API_KEY=

# ─── App URLs ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Admin ───────────────────────────────────────────────────────────────────
# After first signup: UPDATE users SET role='admin' WHERE email='your@email.com'
ADMIN_EMAIL=admin@floraiq.app
